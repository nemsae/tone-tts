{
  "name": "tone-tts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fsd": "steiger ./src",
    "lint:all": "npm run lint && npm run lint:fsd && npm run typecheck && npm run format:check",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "openai": "^6.22.0",
    "socket.io-client": "^4.7.0",
    "svelte": "^5.19.0",
    "svelte-spa-router": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@feature-sliced/steiger-plugin": "^0.5.7",
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.3.1",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.3.1",
    "sass": "^1.94.2",
    "sass-embedded": "^1.97.3",
    "steiger": "^0.5.11",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
